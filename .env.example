# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — Red Solidaria
#
# Copiá este archivo a `.env` y completá los valores. El `.env` NO se versiona
# (está en .gitignore). Los valores salen del panel de Supabase.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (Supabase / PostgreSQL, vía Prisma) ────────────────────────

# Conexión POOLED (Transaction pooler, puerto 6543). La usa la app en runtime.
# Supabase → Project Settings → Database → Connection string → "Transaction".
# Agregá ?pgbouncer=true al final.
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión DIRECTA (puerto 5432). La usa el CLI de Prisma para las migraciones.
# Supabase → Project Settings → Database → Connection string → "Session"/"Direct".
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase (storage de fotos) ──────────────────────────────────────────────

# URL del proyecto. Supabase → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"

# Clave pública anónima (segura para el navegador; respeta RLS).
# Supabase → Project Settings → API → Project API keys → anon public.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Clave service role (SALTA RLS). SOLO en el servidor, nunca exponer al cliente.
# Supabase → Project Settings → API → Project API keys → service_role.
SUPABASE_SERVICE_ROLE_KEY=""
